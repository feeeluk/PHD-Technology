#!/bin/bash

TARGET=$1

if [ "$TARGET" != "test" ] && [ "$TARGET" != "live" ]; then
    echo "Usage: deploy-all [test|live]"
    exit 1
fi

BASE_DIR="$HOME/projects"
EXCLUDES=("quiz" "philhenningv2" "projects")

echo "Running FULL SYNC deploy-all → $TARGET"
echo

for PROJECT in "$BASE_DIR"/*; do
    NAME=$(basename "$PROJECT")

    # Skip excluded projects
    if [[ " ${EXCLUDES[@]} " =~ " $NAME " ]]; then
        echo "Skipping excluded project: $NAME"
        continue
    fi

    # Only deploy directories
    if [ -d "$PROJECT" ]; then
        echo "Deploying $NAME → $TARGET (full sync)"
        (cd "$PROJECT" && deploy "$TARGET" full)
        echo
    fi
done
